# Environment Variables Template
# ===============================
# Copy this file to .env and fill in your actual values
#
# DEFAULT PROVIDER: Ollama (local, free, no rate limits)
# Install at https://ollama.com/download/windows

# ============================================================================
# LLM API CREDENTIALS (Choose ONE provider)
# ============================================================================

# --- Option 1: Ollama (Recommended - Local, Free, No Rate Limits) ---
# Install: https://ollama.com/download/windows
# Pull model: ollama pull llama3.2
HF_TOKEN=ollama

# --- Option 2: OpenRouter (Free tier with rate limits) ---
# Get key at https://openrouter.ai/keys
# HF_TOKEN=sk-or-v1-your-openrouter-key-here

# --- Option 3: Hugging Face Router ---
# HF_TOKEN=hf_your_huggingface_token_here

# --- Option 4: Groq (Free with rate limits) ---
# Get key at https://console.groq.com/keys
# HF_TOKEN=gsk_your_groq_key_here

# --- Option 5: OpenAI ---
# HF_TOKEN=sk-proj-your_openai_key_here

# ============================================================================
# API CONFIGURATION
# ============================================================================

# LLM API Base URL (must match your chosen provider)

# Ollama (default - local)
API_BASE_URL=http://localhost:11434/v1

# OpenRouter (alternative)
# API_BASE_URL=https://openrouter.ai/api/v1

# Hugging Face Router (alternative)
# API_BASE_URL=https://router.huggingface.co/v1

# Groq (alternative)
# API_BASE_URL=https://api.groq.com/openai/v1

# OpenAI (alternative)
# API_BASE_URL=https://api.openai.com/v1

# Model to use (must match your chosen provider)

# Ollama models (default)
MODEL_NAME=llama3.2

# Ollama alternative (better quality, slower)
# MODEL_NAME=llama3.1

# OpenRouter models
# MODEL_NAME=meta-llama/llama-3.1-8b-instruct:free

# Hugging Face models
# MODEL_NAME=meta-llama/Meta-Llama-3-70B-Instruct

# Groq models
# MODEL_NAME=llama-3.1-70b-versatile

# OpenAI models
# MODEL_NAME=gpt-4-turbo

# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================

# Local Docker image name (competition requirement)
LOCAL_IMAGE_NAME=email-triage:latest

# Email Triage Server URL
ENV_BASE_URL=http://localhost:8000

# Number of episodes to run
NUM_EPISODES=3

# Database path
EMAIL_TRIAGE_DB=email_triage.db

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server host
SERVER_HOST=0.0.0.0

# Server port
SERVER_PORT=8000

# Number of workers
SERVER_WORKERS=1

# ============================================================================
# ANALYTICS CONFIGURATION
# ============================================================================

# Analytics dashboard port
ANALYTICS_PORT=8501

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable debug logging
DEBUG=false
